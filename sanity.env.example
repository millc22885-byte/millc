# Copy these into .env.local and replace with your Sanity project values.
# Create a project at https://sanity.io/manage or run: npx sanity init

NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Required for customer review submissions from the website.
# Create a token at https://sanity.io/manage with Editor permissions.
SANITY_API_WRITE_TOKEN=
